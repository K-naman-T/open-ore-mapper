# === Docker image tag – interpolated by docker-compose.yml ===
GITHUB_REPOSITORY=open-ore-mapper
IMAGE_TAG=latest

# === NASA Earthdata – EMIT scene search/download ===
# Auth methods: EARTHDATA_TOKEN (scripts) or EARTHDATA_USERNAME+EARTHDATA_PASSWORD (API/earthaccess)
EARTHDATA_TOKEN=
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# === DLR EOWEB – EnMAP/DESIS downloads (scripts/download_hyperspectral.py) ===
EOWEB_USER=
EOWEB_PASSWORD=

# === ASI PRISMA – PRISMA scene search (scripts/download_hyperspectral.py) ===
PRISMA_TOKEN=

# === USGS M2M – Hyperion EO-1 scene search (scripts/download_hyperspectral.py) ===
USGS_API_KEY=

# === RELAB spectral library cache directory (relab_fetcher.py) ===
OPEN_ORE_MAPPER_CACHE=
